{
  "manifest_version": 3,
  "name": "Emozzk Lite Beta",
  "version": "0.1.0",
  "description": "CHZZK emote shortcut helper - beta test build",
  "permissions": [
    "storage",
    "tabs"
  ],
  "host_permissions": [
    "https://chzzk.naver.com/*"
  ],
  "action": {
    "default_title": "Emozzk Lite",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "icons/*",
        "inject.js"
      ],
      "matches": [
        "https://chzzk.naver.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  },
  "version_name": "0.1.0-beta.20260624-0332"
}
