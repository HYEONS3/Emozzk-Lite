{
  "manifest_version": 3,
  "name": "Emozzk Lite",
  "version": "0.1.1",
  "description": "CHZZK emote shortcut helper",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Emozzk Lite",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://chzzk.naver.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}