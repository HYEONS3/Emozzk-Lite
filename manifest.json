{
  "manifest_version": 3,
  "name": "Emozzk - 치지직 이모티콘 단축키",
  "version": "0.2.1",
  "description": "자주 쓰는 치지직 이모티콘을 즐겨찾기에 모아두고, 원하는 키에 등록해 바로 사용할 수 있게 해주는 브라우저 확장 프로그램입니다.",
  "permissions": [
    "storage"
  ],
  "action": {
    "default_title": "Emozzk - 치지직 이모티콘 단축키",
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": [
        "https://chzzk.naver.com/*"
      ],
      "js": [
        "content.js"
      ],
      "css": [
        "content.css"
      ],
      "run_at": "document_idle"
    }
  ],
  "web_accessible_resources": [
    {
      "resources": [
        "inject.js"
      ],
      "matches": [
        "https://chzzk.naver.com/*"
      ]
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}